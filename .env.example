# ==========================================
# AgeGate — Environment Variables Template
# Copy this file to .env.local and fill in your values
# ==========================================

# ------------------------------------------------------------------
# 1. Supabase (Database + Auth + Edge Functions)
# ------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_ID=your-project-id
SUPABASE_ACCESS_TOKEN=your-management-api-token

# ------------------------------------------------------------------
# 2. Stripe (Payments & Subscriptions)
# ------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_FREE=price_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ------------------------------------------------------------------
# 3. Application
# ------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
APP_SECRET=generate-a-random-32-char-secret-here

# ------------------------------------------------------------------
# 4. Analytics (Optional)
# ------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ------------------------------------------------------------------
# 5. Support / Notifications (Optional)
# ------------------------------------------------------------------
SUPPORT_EMAIL=support@agegate.dev
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ------------------------------------------------------------------
# 6. Edge Function Secrets (set via Supabase CLI, not .env)
#    These are listed here for reference only.
# ------------------------------------------------------------------
# STRIPE_SECRET_KEY          (same as above)
# APP_SECRET                 (same as above)
# WEBHOOK_SECRET             (same as above)
# ==========================================
